# Local-only port for `npm run dev`.
# Vercel will provide its own runtime port in production.
PORT=4000

NODE_ENV=development

# Replace with your hosted PostgreSQL connection string in production.
DATABASE_URL="postgresql://your_postgres_user@localhost:5432/whitespace_cms?schema=public"

# Allowed frontend origin.
# Local: http://localhost:3000
# Vercel: https://your-frontend-domain.vercel.app
CORS_ORIGIN="http://localhost:3000"

# Public backend base URL used to build absolute media URLs.
# Local: http://localhost:4000
# Vercel: https://your-backend-domain.vercel.app
BACKEND_PUBLIC_URL="http://localhost:4000"

# Cloudinary credentials for image uploads stored outside Vercel.
CLOUDINARY_CLOUD_NAME="djxy"
CLOUDINARY_API_KEY="47485"
CLOUDINARY_API_SECRET="Ur0pAXDqznGOo"

ADMIN_USERNAME="admin"
ADMIN_PASSWORD="Admi3456"
ADMIN_AUTH_SECRET="replace-with-a-long-random-string"

# Gmail SMTP example using an App Password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM_EMAIL="your-gmail@gmail.com"
SMTP_FROM_NAME="WhiteSpace"
